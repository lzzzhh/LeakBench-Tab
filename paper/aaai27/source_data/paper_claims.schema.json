{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leakbench-tab.invalid/schema/paper_claims.schema.json",
  "title": "LeakBench-Tab corrected-v2 final paper claim release",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "evidence_tier",
    "protocol_integrity",
    "protocol_amendments",
    "claims",
    "diagnostic_sensitivity",
    "natural",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "evidence_tier": {"const": "confirmatory"},
    "protocol_integrity": {
      "type": "object",
      "required": [
        "dataset_count",
        "mechanism_count",
        "strength_count",
        "model_count",
        "seed_count",
        "expected_cells",
        "successful_cells",
        "completion_rate",
        "models"
      ],
      "properties": {
        "dataset_count": {"const": 20},
        "mechanism_count": {"const": 11},
        "strength_count": {"const": 5},
        "model_count": {"const": 5},
        "seed_count": {"const": 5},
        "expected_cells": {"const": 27500},
        "successful_cells": {"const": 27500},
        "completion_rate": {"const": 1.0},
        "models": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": ["lr", "rf", "catboost", "lightgbm", "tabm"]
          }
        }
      }
    },
    "protocol_amendments": {
      "type": "object",
      "required": ["statistical_inference", "natural_preprocessing"],
      "properties": {
        "statistical_inference": {
          "type": "object",
          "required": [
            "version",
            "discovery_phase",
            "category_test",
            "category_multiplicity",
            "correlation_interval",
            "m08_cluster_draw",
            "m08_seed_effects_preserved",
            "prediction_arrays_bound_directly_to_frozen_task_bundles",
            "m09_reweighting",
            "old_bootstrap_tail_p_accepted",
            "old_independent_cell_cluster_interval_accepted",
            "v1_seed_independent_entity_interval_accepted",
            "threshold_based_profile_claims_allowed"
          ],
          "properties": {
            "version": {"const": "statistical_inference_amendment_v2"},
            "discovery_phase": {"const": "second_post_unblinding_methodological_audit"},
            "category_test": {"const": "exact_two_sided_task_level_sign_flip"},
            "category_multiplicity": {"const": "holm_over_three_declared_contrasts"},
            "correlation_interval": {"const": "joint_paired_dataset_then_seed_resampling_of_D_and_X"},
            "m08_cluster_draw": {"const": "shared_across_seeds_models_and_strengths_within_dataset"},
            "m08_seed_effects_preserved": {"const": true},
            "prediction_arrays_bound_directly_to_frozen_task_bundles": {"const": true},
            "m09_reweighting": {"const": "descriptive_designed_category_reweighting_only"},
            "old_bootstrap_tail_p_accepted": {"const": false},
            "old_independent_cell_cluster_interval_accepted": {"const": false},
            "v1_seed_independent_entity_interval_accepted": {"const": false},
            "threshold_based_profile_claims_allowed": {"const": false}
          }
        },
        "natural_preprocessing": {
          "type": "object",
          "required": [
            "version",
            "fit_scope",
            "unseen_category_policy",
            "globally_encoded_date_strings_accepted",
            "superseded_full_table_category_vocabulary_accepted",
            "replacement_cells"
          ],
          "properties": {
            "version": {"const": "natural_trainfit_categories_v2"},
            "fit_scope": {"const": "training rows only"},
            "unseen_category_policy": {"const": "map_to_reserved_unknown_value"},
            "globally_encoded_date_strings_accepted": {"const": false},
            "superseded_full_table_category_vocabulary_accepted": {"const": false},
            "replacement_cells": {"const": 60}
          }
        }
      }
    },
    "claims": {
      "type": "object",
      "required": [
        "simple_vs_structured",
        "m03_profile",
        "m08_profile",
        "m09_counterexample",
        "detectability_exploitability_relation",
        "D_METHOD_CONDITIONAL"
      ],
      "properties": {
        "simple_vs_structured": {
          "allOf": [
            {"$ref": "#/$defs/finalClaim"},
            {
              "properties": {
                "metrics": {
                  "type": "object",
                  "required": [
                    "difference",
                    "ci_low",
                    "ci_high",
                    "holm_p",
                    "model_positive_direction_count",
                    "model_ci_excludes_zero_count"
                  ]
                }
              }
            }
          ]
        },
        "m03_profile": {"$ref": "#/$defs/profileClaim"},
        "m08_profile": {
          "allOf": [
            {"$ref": "#/$defs/profileClaim"},
            {
              "properties": {
                "metrics": {
                  "type": "object",
                  "required": ["cluster_ci_low", "cluster_ci_high"]
                }
              }
            }
          ]
        },
        "m09_counterexample": {
          "allOf": [
            {"$ref": "#/$defs/profileClaim"},
            {
              "properties": {
                "metrics": {
                  "type": "object",
                  "required": [
                    "designed_category_reweighting_low",
                    "designed_category_reweighting_high",
                    "designed_category_reweighting_is_inferential",
                    "detectability_unit",
                    "complete_one_hot",
                    "encoded_column_count",
                    "semantic_field_count",
                    "representation_conditional"
                  ],
                  "properties": {
                    "designed_category_reweighting_is_inferential": {"const": false},
                    "detectability_unit": {"const": "encoded_column"},
                    "complete_one_hot": {"const": true},
                    "encoded_column_count": {"const": 8},
                    "semantic_field_count": {"const": 1},
                    "representation_conditional": {"const": true}
                  }
                }
              }
            }
          ]
        },
        "detectability_exploitability_relation": {
          "type": "object",
          "required": ["status", "metrics"],
          "properties": {
            "status": {"const": "DESCRIPTIVE_ONLY"},
            "metrics": {
              "type": "object",
              "required": [
                "global_spearman",
                "global_spearman_ci_low",
                "global_spearman_ci_high",
                "category_r2",
                "category_plus_detectability_r2",
                "incremental_r2",
                "incremental_permutation_p",
                "category_lomo_r2",
                "category_plus_detectability_lomo_r2",
                "incremental_lomo_r2"
              ]
            }
          }
        },
        "D_METHOD_CONDITIONAL": {
          "type": "object",
          "required": ["status", "metrics"],
          "properties": {
            "status": {"const": "DESCRIPTIVE_ONLY"},
            "metrics": {
              "type": "object",
              "required": [
                "m03_method_range",
                "conservative_ci_separation",
                "m03_best_evaluated_method",
                "m03_worst_evaluated_method"
              ]
            }
          }
        }
      }
    },
    "diagnostic_sensitivity": {
      "type": "object",
      "required": [
        "status",
        "method_count",
        "expected_cells",
        "successful_cells",
        "completion_rate",
        "primary_method",
        "methods",
        "mechanisms"
      ],
      "properties": {
        "status": {"const": "DESCRIPTIVE_ONLY"},
        "method_count": {"const": 4},
        "expected_cells": {"const": 22000},
        "successful_cells": {"const": 22000},
        "completion_rate": {"const": 1.0},
        "primary_method": {"const": "mutual_information"},
        "methods": {
          "const": [
            "mutual_information",
            "absolute_correlation",
            "lr_coefficient",
            "rf_permutation"
          ]
        },
        "mechanisms": {
          "type": "object",
          "required": ["M03", "M04", "M05"],
          "properties": {
            "M03": {"$ref": "#/$defs/diagnosticMethods"},
            "M04": {"$ref": "#/$defs/diagnosticMethods"},
            "M05": {"$ref": "#/$defs/diagnosticMethods"}
          }
        }
      }
    },
    "natural": {
      "type": "object",
      "required": [
        "status",
        "task_count",
        "model_count",
        "all_task_effects_positive",
        "mean_paired_harm",
        "bootstrap_ci_low",
        "bootstrap_ci_high",
        "exact_sign_flip_p"
      ],
      "properties": {
        "status": {"const": "CASE_STUDY_ONLY"},
        "task_count": {"const": 5},
        "model_count": {"const": 4},
        "all_task_effects_positive": {"type": "boolean"},
        "mean_paired_harm": {"type": "number"},
        "bootstrap_ci_low": {"type": "number"},
        "bootstrap_ci_high": {"type": "number"},
        "exact_sign_flip_p": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "provenance": {"type": "object", "minProperties": 1}
  },
  "$defs": {
    "finalClaim": {
      "type": "object",
      "required": ["status", "metrics"],
      "properties": {
        "status": {"enum": ["SUPPORTED", "NOT_SUPPORTED"]},
        "metrics": {"type": "object"}
      }
    },
    "profileClaim": {
      "type": "object",
      "required": ["status", "metrics"],
      "properties": {
        "status": {"const": "DESCRIPTIVE_ONLY"},
        "metrics": {
          "type": "object",
          "required": [
            "detectability",
            "detectability_ci_low",
            "detectability_ci_high",
            "paired_harm",
            "paired_harm_ci_low",
            "paired_harm_ci_high"
          ]
        }
      }
    },
    "diagnosticPoint": {
      "type": "object",
      "required": ["detectability", "ci_low", "ci_high"],
      "properties": {
        "detectability": {"type": "number"},
        "ci_low": {"type": "number"},
        "ci_high": {"type": "number"}
      }
    },
    "diagnosticMethods": {
      "type": "object",
      "required": [
        "mutual_information",
        "absolute_correlation",
        "lr_coefficient",
        "rf_permutation"
      ],
      "properties": {
        "mutual_information": {"$ref": "#/$defs/diagnosticPoint"},
        "absolute_correlation": {"$ref": "#/$defs/diagnosticPoint"},
        "lr_coefficient": {"$ref": "#/$defs/diagnosticPoint"},
        "rf_permutation": {"$ref": "#/$defs/diagnosticPoint"}
      }
    }
  }
}
