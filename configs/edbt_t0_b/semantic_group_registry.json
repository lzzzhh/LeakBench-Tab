{
  "schema_version": 1,
  "audit": "T0_B_SEMANTIC_GROUP_REGISTRY",
  "description": "Maps each mechanism's encoded columns to semantic source-field groups. Policy selectors access group definitions and sizes but NOT leak_mask or contaminated status. Contamination labels are evaluation-only.",
  "mechanisms": {
    "M01": {
      "category": "simple",
      "family": "direct",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M01_0"],
      "groups": {
        "policy_visible": {
          "M01_source": {
            "group_id": "M01_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group"
          }
        },
        "original_columns": {
          "description": "n_original singleton groups, one per clean feature column",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
        "leak_group_count": 1,
        "note": "The M01_source group is contaminated; original columns are clean"
      }
    },
    "M02": {
      "category": "simple",
      "family": "direct",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M02_0"],
      "groups": {
        "policy_visible": {
          "M02_source": {
            "group_id": "M02_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group"
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
        "leak_group_count": 1
      }
    },
    "M03": {
      "category": "boundary",
      "family": "transform",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M03_0"],
      "groups": {
        "policy_visible": {
          "M03_source": {
            "group_id": "M03_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group. Interacts with x_000."
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
        "leak_group_count": 1
      }
    },
    "M04": {
      "category": "structured",
      "family": "temporal",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M04_0"],
      "groups": {
        "policy_visible": {
          "M04_source": {
            "group_id": "M04_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group. Post-outcome future aggregation."
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
        "leak_group_count": 1
      }
    },
    "M05": {
      "category": "structured",
      "family": "temporal",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M05_0"],
      "groups": {
        "policy_visible": {
          "M05_source": {
            "group_id": "M05_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group. Temporal look-ahead."
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
        "leak_group_count": 1
      }
    },
    "M06": {
      "category": "simple",
      "family": "redundant",
      "n_injected": "dynamic: max(1, int(redundancy))",
      "n_leak": "dynamic: same as n_injected",
      "column_names": ["contam_M06_r0", "contam_M06_r1", "..."],
      "groups": {
        "policy_visible": {
          "M06_redundant_cluster": {
            "group_id": "M06_redundant_cluster",
            "member_encoded_indices": "dynamic: all injected M06 columns (last n_injected columns)",
            "group_size": "dynamic: n_injected",
            "source_role": "contamination_injection",
            "note": "All M06 redundant columns form ONE semantic group. Atomic removal required."
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": "n_injected",
        "leak_group_count": 1
      }
    },
    "M07": {
      "category": "boundary",
      "family": "subgroup",
      "n_injected": 1,
      "n_leak": 1,
      "column_names": ["contam_M07_0"],
      "groups": {
        "policy_visible": {
          "M07_source": {
            "group_id": "M07_source",
            "member_encoded_indices": "dynamic: last 1 column",
            "group_size": 1,
            "source_role": "contamination_injection",
            "note": "Single float column; singleton group. Sparse subgroup coverage."
          }
        },
        "original_columns": {
          "description": "n_original singleton groups",
          "group_size": 1,
          "count": "n_original"
        }
      },
      "contamination_labels": {
        "evaluation_only": true,
        "leak_column_count": 1,
